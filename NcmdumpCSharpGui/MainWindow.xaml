<Window x:Class="NcmdumpCSharpGui.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:NcmdumpCSharpGui.ViewModels"
        xmlns:conv="clr-namespace:NcmdumpCSharpGui.Converters"
        Title="網易雲音樂 NCM 解密工具"
        Width="780" Height="700"
        MinWidth="660" MinHeight="580"
        Background="#F0F2F5"
        FontFamily="Microsoft YaHei UI, Segoe UI, sans-serif"
        FontSize="13">

    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>

    <Window.Resources>
        <!-- 轉換器 -->
        <conv:BoolToVisibilityConverter  x:Key="BoolToVis" />
        <conv:LogLevelToColorConverter   x:Key="LevelToColor" />
        <conv:MinOneConverter            x:Key="MinOne" />

        <!-- ─── 色彩變數 ─────────────────────────────────── -->
        <SolidColorBrush x:Key="PrimaryBrush"       Color="#1558B0" />
        <SolidColorBrush x:Key="PrimaryHoverBrush"  Color="#1A6DD4" />
        <SolidColorBrush x:Key="PrimaryDarkBrush"   Color="#0D3E7A" />
        <SolidColorBrush x:Key="SurfaceBrush"       Color="#FFFFFF" />
        <SolidColorBrush x:Key="BackgroundBrush"    Color="#F0F2F5" />
        <SolidColorBrush x:Key="BorderColorBrush"   Color="#D8DCE4" />
        <SolidColorBrush x:Key="TextBrush"          Color="#1A202C" />
        <SolidColorBrush x:Key="SubTextBrush"       Color="#5A6478" />

        <!-- ─── 主按鈕樣式 ─────────────────────────────────── -->
        <Style x:Key="PrimaryBtn" TargetType="Button">
            <Setter Property="Background"   Value="{StaticResource PrimaryBrush}" />
            <Setter Property="Foreground"   Value="White" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding"      Value="22,9" />
            <Setter Property="FontWeight"   Value="SemiBold" />
            <Setter Property="Cursor"       Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                CornerRadius="5"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background"
                                        Value="{StaticResource PrimaryHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background"
                                        Value="{StaticResource PrimaryDarkBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Root" Property="Background" Value="#B0BEC5" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ─── 次要按鈕樣式 ─────────────────────────────────── -->
        <Style x:Key="SecondaryBtn" TargetType="Button">
            <Setter Property="Background"     Value="Transparent" />
            <Setter Property="Foreground"     Value="{StaticResource PrimaryBrush}" />
            <Setter Property="BorderBrush"    Value="{StaticResource PrimaryBrush}" />
            <Setter Property="BorderThickness" Value="1.5" />
            <Setter Property="Padding"        Value="18,7" />
            <Setter Property="Cursor"         Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="5"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#EBF2FF" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground"  Value="#B0BEC5" />
                                <Setter Property="BorderBrush" Value="#B0BEC5" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ─── 瀏覽按鈕樣式 ─────────────────────────────────── -->
        <Style x:Key="BrowseBtn" TargetType="Button">
            <Setter Property="Background"    Value="#E8ECF2" />
            <Setter Property="Foreground"    Value="#374151" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding"       Value="14,7" />
            <Setter Property="Cursor"        Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                CornerRadius="5"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#C9D3E0" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ─── TextBox 樣式 ─────────────────────────────────── -->
        <Style x:Key="FolderBox" TargetType="TextBox">
            <Setter Property="Background"            Value="White" />
            <Setter Property="BorderBrush"           Value="{StaticResource BorderColorBrush}" />
            <Setter Property="BorderThickness"       Value="1" />
            <Setter Property="Padding"               Value="9,7" />
            <Setter Property="FontSize"              Value="12" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="IsReadOnly"            Value="True" />
            <Style.Triggers>
                <Trigger Property="IsFocused" Value="True">
                    <Setter Property="BorderBrush" Value="{StaticResource PrimaryBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- ─── CheckBox 樣式 ─────────────────────────────────── -->
        <Style x:Key="OptionBox" TargetType="CheckBox">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="Margin"     Value="0,5,0,5" />
            <Setter Property="Cursor"     Value="Hand" />
            <Setter Property="FontSize"   Value="13" />
        </Style>

        <!-- ─── 區塊標題 ─────────────────────────────────── -->
        <Style x:Key="SectionTitle" TargetType="TextBlock">
            <Setter Property="FontSize"   Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource PrimaryBrush}" />
            <Setter Property="Margin"     Value="0,0,0,10" />
        </Style>

        <!-- ─── 卡片邊框樣式 ─────────────────────────────────── -->
        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background"       Value="{StaticResource SurfaceBrush}" />
            <Setter Property="BorderBrush"      Value="{StaticResource BorderColorBrush}" />
            <Setter Property="BorderThickness"  Value="1" />
            <Setter Property="CornerRadius"     Value="8" />
            <Setter Property="Padding"          Value="18,14" />
            <Setter Property="Margin"           Value="0,0,0,12" />
        </Style>

        <!-- ─── 進度條自定義樣式 ─────────────────────────────── -->
        <Style x:Key="ModernProgressBar" TargetType="ProgressBar">
            <Setter Property="Height"     Value="11" />
            <Setter Property="Foreground" Value="{StaticResource PrimaryBrush}" />
            <Setter Property="Background" Value="#DCE4F5" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ProgressBar">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Height="{TemplateBinding Height}">
                            <Grid>
                                <Border x:Name="PART_Track"  CornerRadius="6" />
                                <Border x:Name="PART_Indicator"
                                        Background="{TemplateBinding Foreground}"
                                        CornerRadius="6"
                                        HorizontalAlignment="Left" />
                            </Grid>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <!-- ─── TabControl / TabItem 樣式 ──────────────────────── -->
        <Style x:Key="ModernTab" TargetType="TabControl">
            <Setter Property="Background"       Value="{StaticResource BackgroundBrush}" />
            <Setter Property="BorderThickness"  Value="0" />
            <Setter Property="Padding"          Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabControl">
                        <DockPanel>
                            <Border DockPanel.Dock="Top"
                                    Background="{StaticResource PrimaryDarkBrush}"
                                    Padding="8,0,0,0">
                                <TabPanel IsItemsHost="True" />
                            </Border>
                            <ContentPresenter ContentSource="SelectedContent" />
                        </DockPanel>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="NavTab" TargetType="TabItem">
            <Setter Property="Foreground"      Value="#8AAFD0" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding"         Value="18,10" />
            <Setter Property="FontSize"        Value="13" />
            <Setter Property="Cursor"          Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="Root"
                                Background="Transparent"
                                Padding="{TemplateBinding Padding}"
                                BorderThickness="0,0,0,3"
                                BorderBrush="Transparent">
                            <ContentPresenter ContentSource="Header"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Root" Property="BorderBrush" Value="White" />
                                <Setter Property="Foreground"  Value="White" />
                                <Setter Property="FontWeight"  Value="SemiBold" />
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsMouseOver" Value="True" />
                                    <Condition Property="IsSelected"  Value="False" />
                                </MultiTrigger.Conditions>
                                <Setter Property="Foreground" Value="#C4DCF5" />
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <!-- ════════════════════════════════════════════════════════ -->
    <!--  最外層 DockPanel                                         -->
    <!-- ════════════════════════════════════════════════════════ -->
    <DockPanel>

        <!-- ── 頁首 ─────────────────────────────────────────── -->
        <Border DockPanel.Dock="Top" Height="54" Background="{StaticResource PrimaryBrush}">
            <StackPanel Orientation="Horizontal" Margin="20,0" VerticalAlignment="Center">
                <TextBlock Text="🎵" FontSize="22" Margin="0,0,10,0" VerticalAlignment="Center" />
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="網易雲音樂 NCM 解密工具"
                               Foreground="White" FontSize="17" FontWeight="SemiBold" />
                    <TextBlock Text="支援多執行緒、自動轉換繁體中文、複製非 NCM 檔案"
                               Foreground="#A8C4F0" FontSize="11" Margin="0,1,0,0" />
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- ── 頁籤容器 ─────────────────────────────────────────── -->
        <TabControl Style="{StaticResource ModernTab}">

            <!-- ── 頁籤 1：解密工具 ─────────────────────────────── -->
            <TabItem Style="{StaticResource NavTab}">
                <TabItem.Header>🔓  解密工具</TabItem.Header>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <!-- 可捲動內容 -->
                        <RowDefinition Height="Auto" />
                        <!-- 底部狀態列 -->
                    </Grid.RowDefinitions>

            <ScrollViewer Grid.Row="0"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <StackPanel Margin="18,14,18,4">

                    <!-- ══ 資料夾設定 ══════════════════════════════ -->
                    <Border Style="{StaticResource Card}">
                        <StackPanel>
                            <TextBlock Text="📁  資料夾設定" Style="{StaticResource SectionTitle}" />

                            <!-- 來源資料夾 -->
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="80" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="8" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="來源資料夾"
                                           VerticalAlignment="Center"
                                           Foreground="{StaticResource SubTextBrush}" />
                                <TextBox Grid.Column="1"
                                         Text="{Binding SourceFolder, Mode=OneWay}"
                                         Style="{StaticResource FolderBox}" />
                                <Button Grid.Column="3"
                                        Content="瀏覽..."
                                        Style="{StaticResource BrowseBtn}"
                                        Command="{Binding BrowseSourceCommand}" />
                            </Grid>

                            <!-- 輸出資料夾 -->
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="80" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="8" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="輸出資料夾"
                                           VerticalAlignment="Center"
                                           Foreground="{StaticResource SubTextBrush}" />
                                <TextBox Grid.Column="1"
                                         Text="{Binding OutputFolder, Mode=OneWay}"
                                         Style="{StaticResource FolderBox}" />
                                <Button Grid.Column="3"
                                        Content="瀏覽..."
                                        Style="{StaticResource BrowseBtn}"
                                        Command="{Binding BrowseOutputCommand}" />
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- ══ 處理選項 ══════════════════════════════ -->
                    <Border Style="{StaticResource Card}">
                        <StackPanel>
                            <TextBlock Text="⚙  處理選項" Style="{StaticResource SectionTitle}" />

                            <!-- 繁體中文翻譯 -->
                            <CheckBox Style="{StaticResource OptionBox}"
                                      IsChecked="{Binding TranslateToTraditional}">
                                <TextBlock TextWrapping="Wrap">
                                    <Run Text="✏  自動將檔名及嵌入標籤（歌名、歌手、專輯）轉換為繁體中文" />
                                    <LineBreak />
                                    <Run Text="      使用 Windows 內建 LCMapStringEx 轉換，無需網路連線"
                                         FontSize="11" Foreground="#7A8899" />
                                </TextBlock>
                            </CheckBox>

                            <!-- 複製非 NCM 檔案 -->
                            <CheckBox Style="{StaticResource OptionBox}"
                                      IsChecked="{Binding CopyNonNcmFiles}">
                                <TextBlock TextWrapping="Wrap">
                                    <Run Text="📋  將非 NCM 檔案一併複製至輸出資料夾" />
                                    <LineBreak />
                                    <Run Text="      例如 MP3、FLAC、JPG 等；若已啟用翻譯，也會轉換其檔名"
                                         FontSize="11" Foreground="#7A8899" />
                                </TextBlock>
                            </CheckBox>

                            <!-- 執行緒數量 -->
                            <Grid Margin="0,6,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="10" />
                                    <ColumnDefinition Width="140" />
                                    <ColumnDefinition Width="10" />
                                    <ColumnDefinition Width="30" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="平行執行緒："
                                           VerticalAlignment="Center"
                                           Foreground="{StaticResource SubTextBrush}" />
                                <Slider Grid.Column="2"
                                        Value="{Binding MaxParallelism}"
                                        Minimum="1" Maximum="{Binding MaxParallelismMax}"
                                        TickFrequency="1"
                                        IsSnapToTickEnabled="True"
                                        VerticalAlignment="Center" />
                                <TextBlock Grid.Column="4"
                                           Text="{Binding MaxParallelism}"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource PrimaryBrush}"
                                           VerticalAlignment="Center" />
                                <TextBlock Grid.Column="5"
                                           Foreground="#9AA5B4"
                                           FontSize="11"
                                           VerticalAlignment="Center"
                                           Margin="8,0,0,0">
                                    <Run Text="（上限 " /><Run Text="{Binding MaxParallelismMax, Mode=OneWay}" /><Run Text=" 個 = 實體核心數）" />
                                </TextBlock>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- ══ 動作按鈕列 ══════════════════════════════ -->
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="10" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="10" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <Button Grid.Column="1"
                                Content="▶  開始解密"
                                Style="{StaticResource PrimaryBtn}"
                                Command="{Binding StartCommand}"
                                MinWidth="120" Height="36" />

                        <Button Grid.Column="3"
                                Content="⏹  取消"
                                Style="{StaticResource SecondaryBtn}"
                                Command="{Binding CancelCommand}"
                                Height="36" />

                        <Button Grid.Column="5"
                                Content="清除記錄"
                                Style="{StaticResource SecondaryBtn}"
                                Command="{Binding ClearLogCommand}"
                                Height="36" />
                    </Grid>

                    <!-- ══ 進度區塊 ══════════════════════════════ -->
                    <Border Style="{StaticResource Card}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="10" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="6" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <!-- 標題 + 計數 -->
                            <Grid Grid.Row="0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"
                                           Text="📊  處理進度"
                                           Style="{StaticResource SectionTitle}"
                                           Margin="0" />
                                <TextBlock Grid.Column="1" VerticalAlignment="Center">
                                    <Run Text="{Binding ProcessedCount, Mode=OneWay}"
                                         FontWeight="SemiBold"
                                         Foreground="{StaticResource PrimaryBrush}" />
                                    <Run Text=" / " Foreground="{StaticResource SubTextBrush}" />
                                    <Run Text="{Binding TotalCount, Mode=OneWay}"
                                         FontWeight="SemiBold"
                                         Foreground="{StaticResource TextBrush}" />
                                    <Run Text=" 個檔案" Foreground="{StaticResource SubTextBrush}" />
                                </TextBlock>
                            </Grid>

                            <!-- 進度條 -->
                            <ProgressBar Grid.Row="2"
                                         Style="{StaticResource ModernProgressBar}"
                                         Minimum="0"
                                         Maximum="{Binding ProgressMaximum}"
                                         Value="{Binding ProcessedCount, Mode=OneWay}" />

                            <!-- 當前處理檔案 -->
                            <TextBlock Grid.Row="4"
                                       Text="{Binding CurrentFile, Mode=OneWay}"
                                       Foreground="{StaticResource SubTextBrush}"
                                       FontSize="11"
                                       TextTrimming="CharacterEllipsis"
                                       Visibility="{Binding IsProcessing,
                                                    Converter={StaticResource BoolToVis}}" />
                        </Grid>
                    </Border>

                    <!-- ══ 記錄區塊 ══════════════════════════════ -->
                    <Border Style="{StaticResource Card}" Margin="0,0,0,4">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="8" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0"
                                       Text="📋  處理記錄"
                                       Style="{StaticResource SectionTitle}"
                                       Margin="0" />

                            <ListBox x:Name="LogListBox"
                                     Grid.Row="2"
                                     ItemsSource="{Binding LogEntries}"
                                     BorderThickness="1"
                                     BorderBrush="{StaticResource BorderColorBrush}"
                                     Background="#FAFBFC"
                                     MinHeight="160"
                                     MaxHeight="280"
                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                     VirtualizingPanel.ScrollUnit="Pixel"
                                     SelectionMode="Single">

                                <ListBox.ItemContainerStyle>
                                    <Style TargetType="ListBoxItem">
                                        <Setter Property="Padding" Value="8,3" />
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                        <Setter Property="Background" Value="Transparent" />
                                        <Setter Property="BorderThickness" Value="0" />
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="ListBoxItem">
                                                    <Border Padding="{TemplateBinding Padding}"
                                                            Background="{TemplateBinding Background}">
                                                        <ContentPresenter />
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="Background" Value="#EEF2FF" />
                                                        </Trigger>
                                                        <Trigger Property="IsSelected" Value="True">
                                                            <Setter Property="Background" Value="#DBEAFE" />
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </ListBox.ItemContainerStyle>

                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="62" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0"
                                                       Text="{Binding TimeString}"
                                                       Foreground="#9AA5B4"
                                                       FontSize="11"
                                                       FontFamily="Consolas"
                                                       VerticalAlignment="Top"
                                                       Margin="0,2,0,0" />
                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding Message}"
                                                       FontSize="12"
                                                       TextWrapping="Wrap"
                                                       Foreground="{Binding Level,
                                                           Converter={StaticResource LevelToColor}}" />
                                        </Grid>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Grid>
                    </Border>

                </StackPanel>
            </ScrollViewer>

            <!-- ── 底部狀態列 ────────────────────────────────── -->
            <Border Grid.Row="1"
                    Background="#E9EEF5"
                    BorderBrush="{StaticResource BorderColorBrush}"
                    BorderThickness="0,1,0,0"
                    Padding="18,5">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0"
                               Text="{Binding CurrentFile, Mode=OneWay,
                                      StringFormat='正在處理：{0}'}"
                               Visibility="{Binding IsProcessing,
                                            Converter={StaticResource BoolToVis}}"
                               Foreground="{StaticResource SubTextBrush}"
                               FontSize="11"
                               TextTrimming="CharacterEllipsis"
                               VerticalAlignment="Center" />
                    <TextBlock Grid.Column="0"
                               Text="就緒"
                               Visibility="{Binding IsProcessing,
                                            Converter={StaticResource BoolToVis},
                                            ConverterParameter=Invert}"
                               Foreground="{StaticResource SubTextBrush}"
                               FontSize="11"
                               VerticalAlignment="Center">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsProcessing}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                    <TextBlock Grid.Column="1"
                               Foreground="{StaticResource SubTextBrush}"
                               FontSize="11"
                               VerticalAlignment="Center">
                        <Run Text="{Binding ProcessedCount, Mode=OneWay}" />
                        <Run Text=" / " />
                        <Run Text="{Binding TotalCount, Mode=OneWay}" />
                    </TextBlock>
                </Grid>
            </Border>
                </Grid>
            </TabItem>

            <!-- ════════════════════════════════════════════════════ -->
            <!--  頁籤 2：重複檔案掃描                                  -->
            <!-- ════════════════════════════════════════════════════ -->
            <TabItem Style="{StaticResource NavTab}">
                <TabItem.Header>🔍  重複掃描</TabItem.Header>
                <Grid Background="{StaticResource BackgroundBrush}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <ScrollViewer Grid.Row="0"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <StackPanel Margin="18,14,18,4">

                            <!-- ══ 掃描設定 ════════════════════════ -->
                            <Border Style="{StaticResource Card}">
                                <StackPanel>
                                    <TextBlock Text="🔍  掃描設定" Style="{StaticResource SectionTitle}" />
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="80" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="8" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="掃描資料夾"
                                                   VerticalAlignment="Center"
                                                   Foreground="{StaticResource SubTextBrush}" />
                                        <TextBox Grid.Column="1"
                                                 Text="{Binding DupVm.ScanFolder, Mode=OneWay}"
                                                 Style="{StaticResource FolderBox}" />
                                        <Button Grid.Column="3"
                                                Content="瀏覽..."
                                                Style="{StaticResource BrowseBtn}"
                                                Command="{Binding DupVm.BrowseFolderCommand}" />
                                    </Grid>
                                    <TextBlock Margin="0,10,0,0" FontSize="11"
                                               Foreground="{StaticResource SubTextBrush}"
                                               TextWrapping="Wrap">
                                        掃描所有子資料夾中的音訊檔案（MP3、FLAC、M4A 等）。優先依嵌入標籤的歌名＋歌手辨識重複；
                                        若無標籤則依檔名中的 <Run FontFamily="Consolas">(1)</Run>、<Run FontFamily="Consolas">(2)</Run>
                                        等序號辨識副本。
                                    </TextBlock>
                                </StackPanel>
                            </Border>

                            <!-- ══ 動作按鈕列 ══════════════════════ -->
                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Button Grid.Column="1"
                                        Content="▶  開始掃描"
                                        Style="{StaticResource PrimaryBtn}"
                                        Command="{Binding DupVm.ScanCommand}"
                                        Width="120" Height="36" />
                                <Button Grid.Column="3"
                                        Style="{StaticResource SecondaryBtn}"
                                        Command="{Binding DupVm.DeleteSelectedCommand}"
                                        Height="36" MinWidth="130">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="🗑  刪除已勾選（" />
                                        <TextBlock Text="{Binding DupVm.SelectedCount, Mode=OneWay}"
                                                   FontWeight="SemiBold" />
                                        <TextBlock Text=" 個）" />
                                    </StackPanel>
                                </Button>
                            </Grid>

                            <!-- ══ 狀態 / 進度 ═════════════════════ -->
                            <Border Style="{StaticResource Card}" Margin="0,0,0,12">
                                <StackPanel>
                                    <ProgressBar Style="{StaticResource ModernProgressBar}"
                                                 IsIndeterminate="True"
                                                 Margin="0,0,0,8"
                                                 Visibility="{Binding DupVm.IsScanning,
                                                              Converter={StaticResource BoolToVis}}" />
                                    <TextBlock Text="{Binding DupVm.StatusText}"
                                               FontSize="13"
                                               Foreground="{StaticResource SubTextBrush}" />
                                </StackPanel>
                            </Border>

                            <!-- ══ 重複清單 ════════════════════════ -->
                            <ItemsControl ItemsSource="{Binding DupVm.DuplicateGroups}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Style="{StaticResource Card}">
                                            <StackPanel>

                                                <!-- 群組標題列 -->
                                                <Grid Margin="0,0,0,8">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel Grid.Column="0" Margin="0,0,12,0">
                                                        <TextBlock Text="{Binding GroupLabel}"
                                                                   FontWeight="SemiBold" FontSize="13"
                                                                   Foreground="{StaticResource TextBrush}"
                                                                   TextWrapping="Wrap" />
                                                        <TextBlock Text="{Binding CountLabel}"
                                                                   FontSize="11"
                                                                   Foreground="{StaticResource SubTextBrush}"
                                                                   Margin="0,2,0,0" />
                                                    </StackPanel>
                                                    <!-- 群組操作按鈕 -->
                                                    <StackPanel Grid.Column="1" Orientation="Horizontal"
                                                                VerticalAlignment="Top">
                                                        <Button Content="保留第一個"
                                                                Style="{StaticResource SecondaryBtn}"
                                                                Command="{Binding KeepFirstCommand}"
                                                                Padding="8,4" Margin="0,0,6,0"
                                                                FontSize="11" />
                                                        <Button Content="全選"
                                                                Style="{StaticResource SecondaryBtn}"
                                                                Command="{Binding SelectAllCommand}"
                                                                Padding="8,4" Margin="0,0,6,0"
                                                                FontSize="11" />
                                                        <Button Content="全不選"
                                                                Style="{StaticResource SecondaryBtn}"
                                                                Command="{Binding SelectNoneCommand}"
                                                                Padding="8,4" FontSize="11" />
                                                    </StackPanel>
                                                </Grid>

                                                <!-- 分隔線 -->
                                                <Border Height="1"
                                                        Background="{StaticResource BorderColorBrush}"
                                                        Margin="0,0,0,6" />

                                                <!-- 檔案列表 -->
                                                <ItemsControl ItemsSource="{Binding Items}">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <Grid Margin="0,4">
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="22" />
                                                                    <ColumnDefinition Width="*" />
                                                                    <ColumnDefinition Width="72" />
                                                                </Grid.ColumnDefinitions>
                                                                <CheckBox Grid.Column="0"
                                                                          IsChecked="{Binding IsSelected}"
                                                                          VerticalAlignment="Center"
                                                                          Cursor="Hand" />
                                                                <StackPanel Grid.Column="1" Margin="6,0,8,0">
                                                                    <TextBlock Text="{Binding FileName}"
                                                                               FontSize="12"
                                                                               Foreground="{StaticResource TextBrush}" />
                                                                    <TextBlock Text="{Binding FolderPath}"
                                                                               FontSize="10"
                                                                               Foreground="{StaticResource SubTextBrush}"
                                                                               TextTrimming="CharacterEllipsis" />
                                                                </StackPanel>
                                                                <TextBlock Grid.Column="2"
                                                                           Text="{Binding DisplaySize}"
                                                                           FontSize="11"
                                                                           Foreground="{StaticResource SubTextBrush}"
                                                                           HorizontalAlignment="Right"
                                                                           VerticalAlignment="Center" />
                                                            </Grid>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>

                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                        </StackPanel>
                    </ScrollViewer>

                    <!-- ── 底部狀態列 ─────────────────────────── -->
                    <Border Grid.Row="1"
                            Background="#E9EEF5"
                            BorderBrush="{StaticResource BorderColorBrush}"
                            BorderThickness="0,1,0,0"
                            Padding="18,5">
                        <TextBlock Text="{Binding DupVm.StatusText}"
                                   Foreground="{StaticResource SubTextBrush}"
                                   FontSize="11"
                                   VerticalAlignment="Center"
                                   TextTrimming="CharacterEllipsis" />
                    </Border>
                </Grid>
            </TabItem>

        </TabControl>
    </DockPanel>
</Window>
